<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Payment received</title></head>
<body style="margin:0;padding:32px 16px;background:#fafafa;font-family:system-ui,sans-serif;color:#18181b;">
  <table width="100%" style="max-width:520px;margin:0 auto;background:#fff;border:1px solid #e4e4e7;border-radius:12px;">
    <tr><td style="padding:28px;">
      <h1 style="margin:0 0 12px;font-size:22px;">Payment received</h1>
      <p style="margin:0 0 16px;line-height:1.5;color:#52525b;">Hi <%= customerName %>, we received <strong><%= amount %></strong> for order <strong><%= orderNumber %></strong> at <%= storeName %>.</p>
      <p style="margin:0 0 8px;font-size:14px;">Transaction ID: <code><%= transactionId %></code></p>
      <p style="margin:0 0 20px;font-size:13px;color:#71717a;">Paid at <%= new Date(paidAt).toLocaleString() %></p>
      <p style="margin:0;font-size:14px;"><a href="<%= orderUrl %>">View order</a></p>
    </td></tr>
  </table>
</body>
</html>
