<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= subject || headline %></title>
</head>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:system-ui,sans-serif;color:#18181b;">
  <% if (previewText) { %><div style="display:none;max-height:0;overflow:hidden;"><%= previewText %></div><% } %>
  <table width="100%" cellpadding="0" cellspacing="0" style="padding:32px 16px;">
    <tr><td align="center">
      <table width="100%" style="max-width:600px;background:#fff;border:1px solid #e4e4e7;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:28px 28px 12px;">
          <% if (logoUrl) { %><img src="<%= logoUrl %>" alt="<%= brandName %>" style="height:36px;margin-bottom:16px;" /><% } else { %>
          <p style="margin:0 0 16px;font-weight:600;font-size:18px;"><%= brandName %></p><% } %>
          <% if (headline) { %><h1 style="margin:0 0 12px;font-size:26px;line-height:1.2;color:<%= primaryColor %>;"><%= headline %></h1><% } %>
          <% if (bodyHtml) { %><div style="color:#52525b;line-height:1.6;margin-bottom:20px;"><%- bodyHtml %></div><% } %>
          <% if (couponCode) { %>
          <div style="margin:20px 0;padding:16px;border:1px dashed <%= primaryColor %>;border-radius:8px;text-align:center;">
            <p style="margin:0 0 6px;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:#71717a;">Use code</p>
            <p style="margin:0;font-size:24px;font-weight:700;color:<%= primaryColor %>;"><%= couponCode %></p>
          </div>
          <% } %>
        </td></tr>
        <% if (products && products.length) { %>
        <tr><td style="padding:0 20px 20px;">
          <table width="100%" cellpadding="0" cellspacing="0">
            <% products.forEach(function(product) { %>
            <tr>
              <td style="padding:12px 8px;border-top:1px solid #f4f4f5;">
                <table width="100%"><tr>
                  <% if (product.image) { %><td width="72" style="vertical-align:top;"><img src="<%= product.image %>" alt="<%= product.name %>" width="64" height="64" style="object-fit:cover;border-radius:8px;" /></td><% } %>
                  <td style="vertical-align:top;padding-left:12px;">
                    <p style="margin:0 0 4px;font-weight:600;"><%= product.name %></p>
                    <p style="margin:0 0 8px;"><span style="font-weight:600;"><%= product.price %></span>
                    <% if (product.compareAt) { %> <span style="color:#a1a1aa;text-decoration:line-through;margin-left:6px;"><%= product.compareAt %></span><% } %></p>
                    <a href="<%= product.url %>" style="color:<%= primaryColor %>;font-size:13px;font-weight:600;">View product</a>
                  </td>
                </tr></table>
              </td>
            </tr>
            <% }) %>
          </table>
        </td></tr>
        <% } %>
        <tr><td style="padding:0 28px 28px;">
          <a href="<%= ctaUrl %>" style="display:inline-block;background:<%= primaryColor %>;color:#fff;text-decoration:none;padding:12px 22px;border-radius:999px;font-weight:600;"><%= ctaLabel %></a>
          <p style="margin:24px 0 0;font-size:12px;color:#a1a1aa;line-height:1.5;"><%= footerText %><br><a href="<%= unsubscribeUrl %>" style="color:#71717a;">Unsubscribe</a></p>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
