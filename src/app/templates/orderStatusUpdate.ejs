<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Order update</title></head>
<body style="margin:0;padding:32px 16px;background:#fafafa;font-family:system-ui,sans-serif;">
  <table width="100%" style="max-width:520px;margin:0 auto;background:#fff;border:1px solid #e4e4e7;border-radius:12px;">
    <tr><td style="padding:28px;">
      <h1 style="margin:0 0 12px;font-size:22px;">Order status updated</h1>
      <p style="line-height:1.5;">Hi <%= customerName %>, order <strong><%= orderNumber %></strong> is now <strong><%= newStatus %></strong> (was <%= previousStatus %>).</p>
      <p style="margin-top:20px;"><a href="<%= orderUrl %>">View order</a></p>
    </td></tr>
  </table>
</body>
</html>
