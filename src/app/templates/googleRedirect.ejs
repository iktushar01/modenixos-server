<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= appName %> | Redirecting</title>
    <style>
        :root {
            --background: #ffffff;
            --foreground: #0f172a;
            --muted: #64748b;
            --border: #e2e8f0;
            --muted-bg: #f1f5f9;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --background: #09090b;
                --foreground: #f4f4f5;
                --muted: #a1a1aa;
                --border: #27272a;
                --muted-bg: #18181b;
            }
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: var(--background);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: var(--foreground);
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            width: 100%;
            max-width: 360px;
            text-align: center;
        }

        .spinner-box {
            margin: 0 auto 1rem;
            display: flex;
            height: 2.25rem;
            width: 2.25rem;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            border: 1px solid var(--border);
            background-color: var(--muted-bg);
        }

        .spinner {
            width: 1rem;
            height: 1rem;
            border: 2px solid var(--muted);
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        h1 {
            font-size: 1.25rem;
            font-weight: 600;
            margin: 0 0 0.375rem;
            tracking: -0.025em;
        }

        p {
            color: var(--muted);
            font-size: 0.875rem;
            margin: 0 0 1.5rem;
            line-height: 1.5;
        }

        .status-card {
            border: 1px solid var(--border);
            background-color: var(--muted-bg);
            border-radius: 6px;
            padding: 0.625rem 0.75rem;
            text-align: left;
        }

        .status-flex {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .status-pulse {
            color: var(--muted);
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .5; }
        }

        .btn-link {
            display: inline-block;
            margin-top: 1rem;
            font-size: 0.75rem;
            color: var(--muted);
            text-decoration: underline;
            text-underline-offset: 4px;
        }

        .btn-link:hover {
            color: var(--foreground);
        }
    </style>
</head>
<body>

    <div id="app" class="wrapper">
        <div class="spinner-box">
            <div class="spinner"></div>
        </div>
        <h1>Completing sign in</h1>
        <p>Verifying your session credentials and synchronizing your workspace...</p>
        
        <div class="status-card">
            <div class="status-flex">
                <span>Redirect status</span>
                <span class="status-pulse">Handoff processing</span>
            </div>
        </div>
    </div>

    <script>
        (async () => {
            const container = document.getElementById('app');
            
            try {
                const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({
                        provider: "google",
                        callbackURL: "<%= callbackURL %>"
                    })
                });

                const data = await response.json();

                if (data.url) {
                    window.location.href = data.url;
                } else {
                    throw new Error("Missing redirect URL");
                }
            } catch (error) {
                container.innerHTML = `
                    <div class="spinner-box" style="border-color: #f43f5e; background-color: #fff1f2; color: #e11d48;">!</div>
                    <h1>Sign in failed</h1>
                    <p>We couldn't handle the secure social exchange sequence securely. Please check your network connection.</p>
                    <div class="status-card" style="border-color: #f43f5e; background-color: #fff1f2;">
                        <div class="status-flex" style="color: #e11d48;">
                            <span>Exchange status</span>
                            <span>Network Error</span>
                        </div>
                    </div>
                    <a href="<%= frontendUrl %>/login" class="btn-link">Return to safe login</a>
                `;
            }
        })();
    </script>
</body>
</html>