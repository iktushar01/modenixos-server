<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Access</title>
</head>
<body style="margin: 0; padding: 0; background-color: #fafafa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; -webkit-font-smoothing: antialiased;">

<table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #fafafa; margin: 0; padding: 48px 16px;">
  <tr>
    <td align="center">
      
      <table width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width: 420px; background-color: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px; box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05); text-align: left;">
        <tr>
          <td style="padding: 32px;">
            
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
              <tr>
                <td style="padding-bottom: 24px;">
                  <span style="font-size: 15px; font-weight: 600; tracking: -0.02em; color: #09090b;">
                    <%= appName %>
                  </span>
                </td>
              </tr>
            </table>

            <table width="100%" border="0" cellspacing="0" cellpadding="0">
              <tr>
                <td style="padding-bottom: 24px;">
                  <h1 style="margin: 0 0 8px 0; font-size: 20px; font-weight: 600; tracking: -0.025em; color: #09090b; line-height: 1.3;">
                    Verify your identity
                  </h1>
                  <p style="margin: 0; font-size: 14px; line-height: 1.5; color: #52525b;">
                    Hello <%= name %>, use the verification token below to secure your session and gain access to your <%= appName %> account.
                  </p>
                </td>
              </tr>
            </table>

            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border: 1px solid #e4e4e7; background-color: #f4f4f5; border-radius: 8px; margin-bottom: 24px;">
              <tr>
                <td align="center" style="padding: 24px 16px;">
                  <div style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 36px; font-weight: 700; letter-spacing: 6px; color: #09090b; padding-left: 6px;">
                    <%= otp %>
                  </div>
                  <div style="margin-top: 8px; font-size: 12px; font-weight: 400; color: #71717a;">
                    This token expires in 15 minutes.
                  </div>
                </td>
              </tr>
            </table>

            <table width="100%" border="0" cellspacing="0" cellpadding="0">
              <tr>
                <td style="padding-bottom: 28px;">
                  <p style="margin: 0; font-size: 13px; line-height: 1.4; color: #71717a;">
                    If you did not make this request, you can safely ignore this transaction email. Your credentials remain private.
                  </p>
                </td>
              </tr>
            </table>

            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border-top: 1px solid #e4e4e7; padding-top: 24px;">
              <tr>
                <td>
                  <p style="margin: 0; font-size: 12px; color: #a1a1aa; line-height: 1.5;">
                    &copy; <%= new Date().getFullYear() %> <%= appName %>. <br>
                    Automated transactional confirmation notification.
                  </p>
                </td>
              </tr>
            </table>

          </td>
        </tr>
      </table>

    </td>
  </tr>
</table>

</body>
</html>