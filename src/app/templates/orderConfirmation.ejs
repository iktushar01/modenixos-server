<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Order confirmed</title></head>
<body style="margin:0;padding:32px 16px;background:#fafafa;font-family:system-ui,sans-serif;color:#18181b;">
  <table width="100%" style="max-width:520px;margin:0 auto;background:#fff;border:1px solid #e4e4e7;border-radius:12px;">
    <tr><td style="padding:28px;">
      <p style="margin:0 0 8px;font-size:13px;color:#71717a;"><%= storeName %></p>
      <h1 style="margin:0 0 12px;font-size:22px;">Order confirmed</h1>
      <p style="margin:0 0 20px;line-height:1.5;color:#52525b;">Hi <%= customerName %>, thanks for your order <strong><%= orderNumber %></strong>.</p>
      <% if (invoiceNumber) { %><p style="margin:0 0 16px;font-size:13px;color:#71717a;">Invoice: <%= invoiceNumber %></p><% } %>
      <table width="100%" style="border-collapse:collapse;margin-bottom:20px;font-size:14px;">
        <% items.forEach(function(item) { %>
        <tr><td style="padding:8px 0;border-bottom:1px solid #f4f4f5;"><%= item.name %> × <%= item.quantity %></td><td align="right" style="padding:8px 0;border-bottom:1px solid #f4f4f5;"><%= item.lineTotal %></td></tr>
        <% }) %>
        <tr><td style="padding:10px 0;">Subtotal</td><td align="right"><%= subtotal %></td></tr>
        <tr><td style="padding:4px 0;">Shipping</td><td align="right"><%= shipping %></td></tr>
        <% if (discount) { %><tr><td style="padding:4px 0;">Discount</td><td align="right">-<%= discount %></td></tr><% } %>
        <tr><td style="padding:10px 0;font-weight:600;">Total (<%= paymentMethod %>)</td><td align="right" style="font-weight:600;"><%= total %></td></tr>
      </table>
      <p style="margin:0 0 16px;font-size:14px;"><a href="<%= orderUrl %>" style="color:#18181b;">View your order</a> · <a href="<%= trackUrl %>" style="color:#18181b;">Track order</a></p>
      <p style="margin:0;font-size:12px;color:#a1a1aa;">&copy; <%= new Date().getFullYear() %> <%= appName %></p>
    </td></tr>
  </table>
</body>
</html>
