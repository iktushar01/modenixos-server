<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop invitation</title>
</head>
<body style="margin: 0; padding: 0; background-color: #fafafa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #fafafa; margin: 0; padding: 48px 16px;">
    <tr>
      <td align="center">
        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width: 420px; background-color: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px;">
          <tr>
            <td style="padding: 32px;">
              <p style="margin: 0 0 8px; font-size: 15px; font-weight: 600; color: #09090b;"><%= appName %></p>
              <h1 style="margin: 0 0 16px; font-size: 22px; font-weight: 700; color: #09090b;">You're invited to <%= storeName %></h1>
              <p style="margin: 0 0 16px; font-size: 14px; line-height: 1.6; color: #52525b;">
                <%= inviterName %> invited you to help manage <strong><%= storeName %></strong> as <strong><%= role %></strong>.
              </p>
              <p style="margin: 0 0 24px; font-size: 14px; line-height: 1.6; color: #52525b;">
                Accept the invitation before <%= expiresAt %> to access the shop dashboard.
              </p>
              <a href="<%= inviteUrl %>" style="display: inline-block; background-color: #6d28d9; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600; padding: 12px 20px; border-radius: 8px;">
                Accept invitation
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
